<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>__BUSYSERVE_LABEL__</string>
    <key>ProgramArguments</key>
    <array>
        <string>__BUSYSERVE_PATH__</string>
        <string>--host</string>
        <string>127.0.0.1</string>
        <string>--port</string>
        <string>8631</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/busyserve.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/busyserve.log</string>
</dict>
</plist>
