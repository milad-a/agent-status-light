{
  "//": "Merge this 'hooks' object into ~/.claude/settings.json (back it up first).",
  "//2": "Claude Code has richer events than Cursor: Notification carries a matchable",
  "//3": "notification_type, so 'needs approval' and 'idle' are precise, not inferred.",
  "//4": "'async: true' (Claude Code >= Jan 2026) keeps hooks from blocking the agent;",
  "//5": "remove the field on older versions. SessionEnd stays synchronous on purpose:",
  "//6": "async hooks can be killed mid-teardown and the final 'off' never lands.",
  "hooks": {
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "curl -s -m 2 'http://localhost:8631/light/0/on?color=yellow' >/dev/null 2>&1 || true", "async": true }] }
    ],
    "PreToolUse": [
      { "hooks": [{ "type": "command", "command": "curl -s -m 2 'http://localhost:8631/light/0/on?color=red' >/dev/null 2>&1 || true", "async": true }] }
    ],
    "PostToolUse": [
      { "hooks": [{ "type": "command", "command": "curl -s -m 2 'http://localhost:8631/light/0/on?color=yellow' >/dev/null 2>&1 || true", "async": true }] }
    ],
    "Notification": [
      { "matcher": "permission_prompt", "hooks": [{ "type": "command", "command": "curl -s -m 2 'http://localhost:8631/light/0/on?color=magenta' >/dev/null 2>&1 || true", "async": true }] },
      { "matcher": "idle_prompt", "hooks": [{ "type": "command", "command": "curl -s -m 2 'http://localhost:8631/light/0/off' >/dev/null 2>&1 || true", "async": true }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "curl -s -m 2 'http://localhost:8631/light/0/on?color=green' >/dev/null 2>&1 || true", "async": true }] }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "command", "command": "curl -s -m 2 'http://localhost:8631/light/0/off' >/dev/null 2>&1 || true" }] }
    ]
  }
}
